{
  "name": "neon-arcade-mcp",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "description": "Neon Arcade — a retro arcade with multiple neon games (Snake, Minesweeper, and more), playable as a ChatGPT widget via MCP.",
  "keywords": [
    "neon arcade",
    "retro",
    "snake",
    "minesweeper",
    "chatgpt widget",
    "mcp"
  ],
  "scripts": {
    "start": "tsx src/server.ts",
    "build": "cd web && pnpm run build && cd .. && node scripts/inline-bundle-encoded.js",
    "build:web": "cd web && pnpm run build",
    "build:inline": "node scripts/inline-bundle-encoded.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "dotenv": "^17.2.3",
    "tsx": "^4.19.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "esbuild": "^0.27.0",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}